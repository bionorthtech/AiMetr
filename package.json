{
  "name": "clawdmeter",
  "version": "2.0.0",
  "description": "Clawdmeter — multi-provider AI usage monitor for ESP32 AMOLED device + desktop companion",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-store": "^8.1.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.aimetr.app",
    "productName": "AIMetr",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
